{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>trueforge-org/truecharts//.github/renovate/main.json5"
  ],
  "automerge": true,
  "automergeType": "pr",
  "ignoreTests": true,
  "ignorePaths": [
    "**/*.sops.*",
    "**/.archive/**",
    "**/archive/**",
    "**/resources/**",
    "**/alert-test/**"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Homelab custom GHCR images — HelmRelease values.image.tag (semver@sha256 digest pin)",
      "managerFilePatterns": ["clusters/**/helm-release.yaml"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>ghcr\\.io/nerddotdad/[\\w-]+)\\s+tag:\\s*[\"']?(?<currentValue>[^@\"'\\s#]+)@sha256:(?<currentDigest>[a-fA-F0-9]{64})[\"']?"
      ]
    },
    {
      "customType": "regex",
      "description": "Homelab custom GHCR images — Deployment container image (semver@sha256 digest pin)",
      "managerFilePatterns": ["clusters/**/deployment.yaml"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>ghcr\\.io/nerddotdad/[\\w-]+)\\s+image:\\s*[^:]+:(?<currentValue>[^@\\s#]+)@sha256:(?<currentDigest>[a-fA-F0-9]{64})"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Custom GHCR images — bumped by CI (build-custom-images / build-homelab-docs → sync-custom-image-tags PR)",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/nerddotdad/hermes-homelab",
        "ghcr.io/nerddotdad/homelab-alert-bridge",
        "ghcr.io/nerddotdad/homelab-docs"
      ],
      "enabled": false
    },
    {
      "description": "Talos/kubelet bumps need manual approval (patch/minor/major); OS applies via system-upgrade Plan",
      "matchPackageNames": [
        "ghcr.io/siderolabs/kubelet",
        "ghcr.io/siderolabs/installer"
      ],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "dependencyDashboardApproval": true,
      "automerge": false
    }
  ]
}
