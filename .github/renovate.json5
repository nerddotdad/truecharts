// Custom images: Renovate opens PRs when a new semver tag appears on GHCR.
// Maps to scripts/custom_image_manifest_map.yaml — only those three manifests are scanned.
// Setup: .github/RENOVATE-GHCR.md (PAT hostRule if PRs stay errored).
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>trueforge-org/truecharts//.github/renovate/main.json5"
  ],
  "automerge": true,
  "automergeType": "pr",
  "ignoreTests": true,
  "ignorePaths": [
    "**/*.sops.*",
    "**/.archive/**",
    "**/archive/**",
    "**/resources/**",
    "**/alert-test/**"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Custom GHCR — HelmRelease image.tag (hermes-homelab, homelab-docs)",
      "managerFilePatterns": [
        "/clusters/main/kubernetes/my-apps/ai/hermes-oncall/app/helm-release\\.yaml/",
        "/clusters/main/kubernetes/my-apps/dashboards/homelab-docs/app/helm-release\\.yaml/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>ghcr\\.io/nerddotdad/[\\w-]+)\\s+tag:\\s*[\"']?(?<currentValue>\\d+\\.\\d+\\.\\d+)@sha256:(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "{{depName}}",
      "versioningTemplate": "semver",
      "autoReplaceStringTemplate": "{{newValue}}@sha256:{{newDigest}}"
    },
    {
      "customType": "regex",
      "description": "Custom GHCR — Deployment image (homelab-alert-bridge)",
      "managerFilePatterns": [
        "/clusters/main/kubernetes/my-apps/observability/homelab-alert-bridge/app/deployment\\.yaml/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>ghcr\\.io/nerddotdad/[\\w-]+)\\s+image:\\s*[^:]+:(?<currentValue>\\d+\\.\\d+\\.\\d+)@sha256:(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "{{depName}}",
      "versioningTemplate": "semver",
      "autoReplaceStringTemplate": "{{depName}}:{{newValue}}@sha256:{{newDigest}}"
    }
  ],
  "packageRules": [
    {
      "description": "Custom GHCR — no digest-only PRs when CI rebuilds the same semver tag",
      "matchDatasources": ["docker"],
      "matchManagers": ["regex"],
      "matchPackageNames": [
        "ghcr.io/nerddotdad/hermes-homelab",
        "ghcr.io/nerddotdad/homelab-alert-bridge",
        "ghcr.io/nerddotdad/homelab-docs"
      ],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "description": "Custom GHCR — semver version bumps with digest on the new tag",
      "matchDatasources": ["docker"],
      "matchManagers": ["regex"],
      "matchPackageNames": [
        "ghcr.io/nerddotdad/hermes-homelab",
        "ghcr.io/nerddotdad/homelab-alert-bridge",
        "ghcr.io/nerddotdad/homelab-docs"
      ],
      "matchUpdateTypes": ["patch", "minor", "major"],
      "versioning": "semver",
      "pinDigests": true,
      "rangeStrategy": "replace",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["dependencies", "custom-images"],
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "to {{newVersion}}"
    },
    {
      "description": "Talos/kubelet — manual approval",
      "matchPackageNames": [
        "ghcr.io/siderolabs/kubelet",
        "ghcr.io/siderolabs/installer"
      ],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "dependencyDashboardApproval": true,
      "automerge": false
    }
  ]
}
