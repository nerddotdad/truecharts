{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>trueforge-org/truecharts//.github/renovate/main.json5"
  ],
  "automerge": true,
  "automergeType": "pr",
  "ignoreTests": true,
  "ignorePaths": [
    "**/*.sops.*",
    "**/.archive/**",
    "**/archive/**",
    "**/resources/**"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Homelab custom GHCR images — HelmRelease values.image.tag (semver@sha256 digest pin)",
      "managerFilePatterns": ["clusters/**/helm-release.yaml"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+tag:\\s*[\"']?(?<currentValue>[^@\"'\\s#]+)@sha256:(?<currentDigest>[a-fA-F0-9]{64})[\"']?",
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+tag:\\s*[\"']?(?<currentValue>[^\"'\\s#]+)[\"']?"
      ]
    },
    {
      "customType": "regex",
      "description": "Homelab custom GHCR images — Deployment container image (semver@sha256 digest pin)",
      "managerFilePatterns": ["clusters/**/deployment.yaml"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+image:\\s+[^:]+:(?<currentValue>[^@\\s#]+)@sha256:(?<currentDigest>[a-fA-F0-9]{64})",
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+image:\\s+[^:]+:(?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Homelab custom GHCR images — custom_images/*/VERSION semver pin",
      "managerFilePatterns": ["/^custom_images/(?<packageName>[^/]+)/VERSION$/"],
      "matchStrings": ["^(?<currentValue>\\d+\\.\\d+\\.\\d+)\\s*$"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/nerddotdad/{{packageName}}"
    }
  ],
  "packageRules": [
    {
      "description": "Homelab custom GHCR tags — published by build-custom-images / build-homelab-docs",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/nerddotdad/**"],
      "versioning": "semver",
      "pinDigests": true,
      "automerge": true,
      "automergeType": "pr",
      "labels": ["dependencies", "custom-images"]
    },
    {
      "description": "Talos/kubelet bumps need manual approval (patch/minor/major); OS applies via system-upgrade Plan",
      "matchPackageNames": [
        "ghcr.io/siderolabs/kubelet",
        "ghcr.io/siderolabs/installer"
      ],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "dependencyDashboardApproval": true,
      "automerge": false
    }
  ]
}
