{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'github>trueforge-org/truecharts//.github/renovate/main.json5',
  ],
  automerge: true,
  automergeType: 'pr',
  ignoreTests: true,
  ignorePaths: [
    '**/*.sops.*',
    '**/.archive/**',
    '**/archive/**',
    '**/resources/**',
    '**/alert-test/**',
  ],
  // HelmRelease `tag:` is covered by TrueCharts YAML regex + flux.
  // Deployment `image: repo:tag` needs a tiny regex (preset captures the whole ref).
  customManagers: [
    {
      customType: 'regex',
      description: 'Homelab GHCR — Deployment image tags',
      managerFilePatterns: [
        'clusters/**/deployment.yaml',
      ],
      datasourceTemplate: 'docker',
      versioningTemplate: 'semver',
      matchStrings: [
        'image:\\s*(?<depName>ghcr\\.io/nerddotdad/[\\w-]+):(?<currentValue>\\d+\\.\\d+\\.\\d+)\\b',
      ],
    },
  ],
  packageRules: [
    {
      description: 'Homelab GHCR — bare semver only (ignore latest / main-* / calver leftovers)',
      matchPackageNames: [
        'ghcr.io/nerddotdad/hermes-homelab',
        'ghcr.io/nerddotdad/hearth',
      ],
      versioning: 'semver',
    },
    {
      description: 'Talos/kubelet bumps need manual approval (patch/minor/major); OS applies via system-upgrade Plan',
      matchPackageNames: [
        'ghcr.io/siderolabs/kubelet',
        'ghcr.io/siderolabs/installer',
      ],
      matchUpdateTypes: [
        'major',
        'minor',
        'patch',
      ],
      dependencyDashboardApproval: true,
      automerge: false,
    },
    {
      description: 'ImmichFrame — manual approval (frame hardware + Immich API coupling; no automerge)',
      matchPackageNames: [
        'ghcr.io/immichframe/immichframe',
      ],
      dependencyDashboardApproval: true,
      automerge: false,
    },
  ],
}
