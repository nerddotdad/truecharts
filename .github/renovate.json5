{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'github>trueforge-org/truecharts//.github/renovate/main.json5',
  ],
  automerge: true,
  automergeType: 'pr',
  ignoreTests: true,
  ignorePaths: [
    '**/*.sops.*',
    '**/.archive/**',
    '**/archive/**',
    '**/resources/**',
    '**/alert-test/**',
  ],
  customManagers: [
    {
      customType: 'regex',
      description: 'Homelab GHCR — TrueCharts HelmRelease image.tag (semver@sha256)',
      managerFilePatterns: [
        'clusters/**/helm-release.yaml',
      ],
      datasourceTemplate: 'docker',
      versioningTemplate: 'semver',
      matchStringsStrategy: 'combination',
      matchStrings: [
        '# renovate: datasource=docker depName=(?<depName>ghcr\\.io/nerddotdad/[\\w-]+)',
        // currentDigest must include the sha256: prefix — Renovate's newDigest does too
        'tag:\\s*(?<currentValue>\\d+\\.\\d+\\.\\d+)@(?<currentDigest>sha256:[a-fA-F0-9]{64})',
      ],
      autoReplaceStringTemplate:
        'tag: {{#if newValue}}{{{newValue}}}{{else}}{{{currentValue}}}{{/if}}{{#if newDigest}}@{{{newDigest}}}{{/if}}',
    },
    {
      customType: 'regex',
      description: 'Homelab GHCR — Deployment image (semver@sha256)',
      managerFilePatterns: [
        'clusters/**/deployment.yaml',
      ],
      datasourceTemplate: 'docker',
      versioningTemplate: 'semver',
      // Single matchString so replace rewrites the full image line (depName + tag + digest)
      matchStrings: [
        'image:\\s*(?<depName>ghcr\\.io/nerddotdad/[\\w-]+):(?<currentValue>\\d+\\.\\d+\\.\\d+)@(?<currentDigest>sha256:[a-fA-F0-9]{64})',
      ],
      autoReplaceStringTemplate:
        'image: {{{depName}}}:{{#if newValue}}{{{newValue}}}{{else}}{{{currentValue}}}{{/if}}{{#if newDigest}}@{{{newDigest}}}{{/if}}',
    },
  ],
  packageRules: [
    {
      description: 'Homelab GHCR — already pinned semver@sha256; skip global pinDigests (breaks regex replace)',
      matchManagers: [
        'custom.regex',
      ],
      matchPackageNames: [
        'ghcr.io/nerddotdad/hermes-homelab',
        'ghcr.io/nerddotdad/homelab-alert-bridge',
      ],
      pinDigests: false,
      versioning: 'semver',
    },
    {
      description: 'Talos/kubelet bumps need manual approval (patch/minor/major); OS applies via system-upgrade Plan',
      matchPackageNames: [
        'ghcr.io/siderolabs/kubelet',
        'ghcr.io/siderolabs/installer',
      ],
      matchUpdateTypes: [
        'major',
        'minor',
        'patch',
      ],
      dependencyDashboardApproval: true,
      automerge: false,
    },
    {
      description: 'ImmichFrame — manual approval (frame hardware + Immich API coupling; no automerge)',
      matchPackageNames: [
        'ghcr.io/immichframe/immichframe',
      ],
      dependencyDashboardApproval: true,
      automerge: false,
    },
  ],
}
